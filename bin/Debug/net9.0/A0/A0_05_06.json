    {
      "title": "Do → does (He/She/It) + say / tell",
      "rule": "В Present Simple: I/you/we/they do, а he/she/it does.",
      "examples": [
        {
          "en": "He does it much better",
          "ipa": "/hiː dʌz ɪt mʌtʃ ˈbetə/",
