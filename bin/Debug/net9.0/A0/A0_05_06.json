        },
        {
          "en": "She does it very well",
          "ipa": "/ʃiː dʌz ɪt ˈveri wel/",
          "ru": "Она делает это очень хорошо"
        },
        {
          "en": "He often says it",
          "ipa": "/hiː ˈɒfən sez ɪt/",
