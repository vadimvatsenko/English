        {
          "en": "He has a car",
          "ipa": "/hiː hæz ə kɑː/",
          "ru": "У него есть машина"
        }
      ]
    },
    {
      "title": "Like / Need / Look / Seem (He/She/It)",
      "rule": "He/She/It likes/needs/looks/seems + …",
      "examples": [
        {
          "en": "He likes this music",
          "ipa": "/hiː laɪks ðɪs ˈmjuːzɪk/",
          "ru": "Ему нравится эта музыка"
        },
        {
          "en": "She likes this song",
          "ipa": "/ʃiː laɪks ðɪs sɒŋ/",
