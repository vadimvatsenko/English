    {
      "title": "Do → does (He/She/It) + say / tell",
      "rule": "В Present Simple: I/you/we/they do, а he/she/it does. Также: he/she often/sometimes says/tells…",
      "examples": [
        { "en": "He does it much better", "ipa": "/hiː dʌz ɪt mʌtʃ ˈbetə/", "ru": "Он делает это намного лучше" },
        { "en": "She does it very well", "ipa": "/ʃiː dʌz ɪt ˈveri wel/", "ru": "Она делает это очень хорошо" },

        { "en": "He often says it", "ipa": "/hiː ˈɒfən sez ɪt/", "ru": "Он часто говорит это" },

        { "en": "She often tells me about it", "ipa": "/ʃiː ˈɒfən telz miː əˈbaʊt ɪt/", "ru": "Она часто говорит мне об этом" },
        { "en": "She sometimes says it", "ipa": "/ʃiː ˈsʌmtaɪmz sez ɪt/", "ru": "Она иногда говорит это" },
        { "en": "He sometimes tells me about it", "ipa": "/hiː ˈsʌmtaɪmz telz miː əˈbaʊt ɪt/", "ru": "Он иногда говорит мне об этом" }
      ]
    },
    {
      "title": "Y → i + es (study → studies)",
      "rule": "Если слово заканчивается на согласная + y, то y меняется на i и добавляем -es: study → studies. Также: country → countries, city → cities.",
      "examples": [
        { "en": "She studies there", "ipa": "/ʃiː ˈstʌdiz ðeə/", "ru": "Она учится там" }
      ]
    },
    {
      "title": "Style / Design",
      "rule": "She/He likes + this + noun.",
      "examples": [
        { "en": "She likes this style", "ipa": "/ʃiː laɪks ðɪs staɪl/", "ru": "Ей нравится этот стиль" },
        { "en": "He likes this design", "ipa": "/hiː laɪks ðɪs dɪˈzaɪn/", "ru": "Ему нравится этот дизайн" }
      ]
    }
