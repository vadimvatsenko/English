    },
    {
      "title": "Like / Need / Look / Seem (He/She/It)",
      "rule": "He/She/It likes/needs/looks/seems + …",
      "examples": [
        { "en": "He likes this music", "ipa": "/hiː laɪks ðɪs ˈmjuːzɪk/", "ru": "Ему нравится эта музыка" },
        { "en": "She likes this song", "ipa": "/ʃiː laɪks ðɪs sɒŋ/", "ru": "Ей нравится эта песня" },
        { "en": "He likes this program", "ipa": "/hiː laɪks ðɪs ˈprəʊɡræm/", "ru": "Ему нравится эта программа" },
        { "en": "She likes this food", "ipa": "/ʃiː laɪks ðɪs fuːd/", "ru": "Ей нравится эта еда" },

        { "en": "He needs more money", "ipa": "/hiː niːdz mɔː ˈmʌni/", "ru": "Ему нужно больше денег" },
        { "en": "She needs more time", "ipa": "/ʃiː niːdz mɔː taɪm/", "ru": "Ей нужно больше времени" },
        { "en": "He needs your help", "ipa": "/hiː niːdz jɔː help/", "ru": "Ему нужна твоя помощь" },
