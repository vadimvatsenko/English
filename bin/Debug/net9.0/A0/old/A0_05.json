  "sections": [
    {
      "title": "Present Simple: He / She / It + verb + s | \nОкончание -s: произношение [z] / [s] / [ɪz]",
      "rule": "В Present Simple с He/She/It к глаголу обычно добавляем -s/-es. Произношение окончания зависит от последнего звука. | \n [z] после звонких согласных и гласных; [s] после глухих согласных; [ɪz] после -s, -ss, -sh, -ch, -tch, -x, -z, -zz (тогда пишем -es).",
      "examples": [
        { "en": "He loves her", "ipa": "/hiː lʌvz hɜː/", "ru": "Он любит её" },
        { "en": "She plays there very often", "ipa": "/ʃiː pleɪz ðeə ˈveri ˈɒfən/", "ru": "Она играет там очень часто" },
        { "en": "He laughs", "ipa": "/hiː lɑːfs/", "ru": "Он смеётся" },
        { "en": "She watches these video lessons", "ipa": "/ʃiː ˈwɒtʃɪz ðiːz ˈvɪdiəʊ ˈlesnz/", "ru": "Она смотрит эти видео-уроки" },
        { "en": "He teaches English", "ipa": "/hiː ˈtiːtʃɪz ˈɪŋɡlɪʃ/", "ru": "Он учит (преподаёт) английский" }
      ]
    },
    {
      "title": "Live / Help / Travel",
      "rule": "He/She/It + verb+s. Примеры со словами live/help/travel.",
      "examples": [
        { "en": "He lives in this area", "ipa": "/hiː lɪvz ɪn ðɪs ˈeəriə/", "ru": "Он живёт в этом районе" },
        { "en": "She lives in this area", "ipa": "/ʃiː lɪvz ɪn ðɪs ˈeəriə/", "ru": "Она живёт в этом районе" },
        { "en": "It helps me so much", "ipa": "/ɪt helps miː səʊ mʌtʃ/", "ru": "Это помогает мне так сильно" },
        { "en": "He often travels", "ipa": "/hiː ˈɒfən ˈtrævəlz/", "ru": "Он часто путешествует" },
        { "en": "She travels every summer", "ipa": "/ʃiː ˈtrævəlz ˈevri ˈsʌmə/", "ru": "Она путешествует каждое лето" },
        { "en": "It really helps me", "ipa": "/ɪt ˈrɪəli helps miː/", "ru": "Это действительно помогает мне" }
      ]
    },
    {
      "title": "Live in… (London / the United States)",
      "rule": "He/She lives in + место.",
      "examples": [
        { "en": "He lives in London", "ipa": "/hiː lɪvz ɪn ˈlʌndən/", "ru": "Он живёт в Лондоне" },
        { "en": "She lives in the United States", "ipa": "/ʃiː lɪvz ɪn ðə juːˈnaɪtɪd steɪts/", "ru": "Она живёт в Соединённых Штатах" }
      ]
    },
    {
      "title": "Cost: It costs… / This … costs…",
      "rule": "It costs + сумма. This bag/ticket/computer/model costs + сумма.",
      "examples": [
        { "en": "It costs so much money", "ipa": "/ɪt kɒsts səʊ mʌtʃ ˈmʌni/", "ru": "Это стоит так много денег" },
        { "en": "It costs twenty dollars", "ipa": "/ɪt kɒsts ˈtwenti ˈdɒləz/", "ru": "Это стоит двадцать долларов" },
        { "en": "It costs ten euros", "ipa": "/ɪt kɒsts ten ˈjʊərəʊz/", "ru": "Это стоит десять евро" },
        { "en": "It costs fifty pounds", "ipa": "/ɪt kɒsts ˈfɪfti paʊndz/", "ru": "Это стоит пятьдесят фунтов" },
        { "en": "It costs two hundred dollars", "ipa": "/ɪt kɒsts tuː ˈhʌndrəd ˈdɒləz/", "ru": "Это стоит двести долларов" },

        { "en": "This bag costs thirty dollars", "ipa": "/ðɪs bæɡ kɒsts ˈθɜːti ˈdɒləz/", "ru": "Эта сумка стоит тридцать долларов" },
        { "en": "This ticket costs forty dollars", "ipa": "/ðɪs ˈtɪkɪt kɒsts ˈfɔːti ˈdɒləz/", "ru": "Этот билет стоит сорок долларов" },
        { "en": "This ticket costs three hundred dollars", "ipa": "/ðɪs ˈtɪkɪt kɒsts θriː ˈhʌndrəd ˈdɒləz/", "ru": "Этот билет стоит триста долларов" },
        { "en": "This computer costs two thousand dollars", "ipa": "/ðɪs kəmˈpjuːtə kɒsts tuː ˈθaʊzənd ˈdɒləz/", "ru": "Этот компьютер стоит две тысячи долларов" },
        { "en": "This model costs three thousand dollars", "ipa": "/ðɪs ˈmɒdl kɒsts θriː ˈθaʊzənd ˈdɒləz/", "ru": "Эта модель стоит три тысячи долларов" }
      ]
    },
    {
      "title": "Work / Drive",
      "rule": "He/She works… He drives…",
      "examples": [
        { "en": "He drives a car", "ipa": "/hiː draɪvz ə kɑː/", "ru": "Он водит машину" },
        { "en": "She works in a company", "ipa": "/ʃiː wɜːks ɪn ə ˈkʌmpəni/", "ru": "Она работает в компании" },
