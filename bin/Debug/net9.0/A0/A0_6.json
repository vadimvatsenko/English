  "sections": [
    {
      "title": "Present Simple: he / she / it + verb + s",
      "rule": "В Present Simple для he/she/it обычно добавляем -s/-es к глаголу (travel → travels, like → likes, live → lives).",
      "examples": [
        { "en": "She travels every summer", "ipa": "/ʃiː ˈtrævəlz ˈevri ˈsʌmə/", "ru": "Она путешествует каждое лето" },
        { "en": "She likes this food", "ipa": "/ʃiː laɪks ðɪs fuːd/", "ru": "Ей нравится эта еда" },
        { "en": "She lives in the United States", "ipa": "/ʃiː lɪvz ɪn ðə juːˈnaɪtɪd steɪts/", "ru": "Она живёт в Соединённых Штатах" },
        { "en": "She works in a company", "ipa": "/ʃiː wɜːks ɪn ə ˈkʌmpəni/", "ru": "Она работает в компании" },
        { "en": "He drives a car", "ipa": "/hiː draɪvz ə kɑː/", "ru": "Он водит машину" },
        { "en": "He often travels", "ipa": "/hiː ˈɒfən ˈtrævəlz/", "ru": "Он часто путешествует" },
        { "en": "He often says it", "ipa": "/hiː ˈɒfən sez ɪt/", "ru": "Он часто говорит это" },
        { "en": "She sometimes says it", "ipa": "/ʃiː ˈsʌmtaɪmz sez ɪt/", "ru": "Она иногда говорит это" },
        { "en": "She studies there", "ipa": "/ʃiː ˈstʌdiz ðeə/", "ru": "Она учится там" },
        { "en": "She plays there very often", "ipa": "/ʃiː pleɪz ðeə ˈveri ˈɒfən/", "ru": "Она играет там очень часто" },
        { "en": "He teaches English", "ipa": "/hiː ˈtiːtʃɪz ˈɪŋɡlɪʃ/", "ru": "Он преподаёт английский" },
        { "en": "She watches these video lessons", "ipa": "/ʃiː ˈwɒtʃɪz ðiːz ˈvɪdiəʊ ˈlesənz/", "ru": "Она смотрит эти видео-уроки" },
        { "en": "He often laughs", "ipa": "/hiː ˈɒfən lɑːfs/", "ru": "Он часто смеётся" },
        { "en": "She often laughs", "ipa": "/ʃiː ˈɒfən lɑːfs/", "ru": "Она часто смеётся" }
      ]
    },
    {
      "title": "Special forms: have → has, do → does",
      "rule": "В Present Simple: he/she/it has (не have), и he/she/it does (не do).",
      "examples": [
        { "en": "She has a brother", "ipa": "/ʃiː hæz ə ˈbrʌðə/", "ru": "У неё есть брат" },
        { "en": "He has a car", "ipa": "/hiː hæz ə kɑː/", "ru": "У него есть машина" },
        { "en": "She has so many questions", "ipa": "/ʃiː hæz səʊ ˈmeni ˈkwestʃənz/", "ru": "У неё так много вопросов" },
