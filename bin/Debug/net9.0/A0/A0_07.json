  "sections": [
    {
      "title": "I / We / You / They + don't + verb",
      "rule": "Present Simple (отрицание): don't + глагол (I/We/You/They).",
      "examples": [
        { "en": "I don't like this food", "ipa": "/aɪ dəʊnt laɪk ðɪs fuːd/", "ru": "Мне не нравится эта еда" },
        { "en": "I don't want to go there now", "ipa": "/aɪ dəʊnt wɒnt tə ɡəʊ ðeə naʊ/", "ru": "Я не хочу идти туда сейчас" },
        { "en": "We don't see any changes", "ipa": "/wiː dəʊnt siː ˈeni ˈtʃeɪndʒɪz/", "ru": "Мы не видим каких-либо изменений" },
        { "en": "They don't want to say it", "ipa": "/ðeɪ dəʊnt wɒnt tə seɪ ɪt/", "ru": "Они не хотят говорить это" },
        { "en": "I don't know the answer", "ipa": "/aɪ dəʊnt nəʊ ði ˈɑːnsə/", "ru": "Я не знаю ответа" },
        { "en": "I don't have any questions", "ipa": "/aɪ dəʊnt hæv ˈeni ˈkwestʃənz/", "ru": "У меня нет каких-либо вопросов" },
        { "en": "I don't agree with it", "ipa": "/aɪ dəʊnt əˈɡriː wɪð ɪt/", "ru": "Я не согласен с этим" },
        { "en": "I don't think about it", "ipa": "/aɪ dəʊnt θɪŋk əˈbaʊt ɪt/", "ru": "Я не думаю об этом" },
        { "en": "I don't think so", "ipa": "/aɪ dəʊnt θɪŋk səʊ/", "ru": "Я так не думаю" },
        { "en": "I don't ask him about it", "ipa": "/aɪ dəʊnt ɑːsk hɪm əˈbaʊt ɪt/", "ru": "Я не спрашиваю его об этом" },
        { "en": "I don't have any brothers or sisters", "ipa": "/aɪ dəʊnt hæv ˈeni ˈbrʌðəz ɔː ˈsɪstəz/", "ru": "У меня нет каких-либо братьев или сестёр" },
        { "en": "I don't want to stop. I want to continue", "ipa": "/aɪ dəʊnt wɒnt tə stɒp | aɪ wɒnt tə kənˈtɪnjuː/", "ru": "Я не хочу останавливаться. Я хочу продолжать" }
      ]
    },
