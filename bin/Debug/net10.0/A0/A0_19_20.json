{
  "sections": [
    {
      "title": "When / Why / How questions with to be",
      "rule": "When / Why / How + are / is + subject...?",
      "examples": [
        {
          "en": "When are you free?",
          "ipa": "/wen ɑː juː friː?/",
          "ru": "Когда ты свободен?"
        },
        {
          "en": "When are you at work?",
          "ipa": "/wen ɑː juː æt wɜːk?/",
          "ru": "Когда ты на работе?"
        },
        {
          "en": "Why is it so important?",
          "ipa": "/waɪ ɪz ɪt səʊ ɪmˈpɔːtənt?/",
          "ru": "Почему это так важно?"
        },
        {
          "en": "Why is it so expensive?",
          "ipa": "/waɪ ɪz ɪt səʊ ɪkˈspensɪv?/",
          "ru": "Почему это так дорого?"
        },
        {
          "en": "How are you?",
          "ipa": "/haʊ ɑː juː?/",
          "ru": "Как дела? (Как ты?)"
        },
        {
          "en": "How is he?",
          "ipa": "/haʊ ɪz hiː?/",
          "ru": "Как у него дела? (Как он?)"
        },
        {
          "en": "How is she?",
          "ipa": "/haʊ ɪz ʃiː?/",
          "ru": "Как у неё дела? (Как она?)"
        },
        {
          "en": "How are they?",
          "ipa": "/haʊ ɑː ðeɪ?/",
          "ru": "Как у них дела? (Как они?)"
        }
      ]
    },
    {
