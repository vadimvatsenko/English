        {
          "en": "What's here?",
          "ipa": "/wɒts hɪə?/",
          "ru": "Что здесь?"
        },
        {
          "en": "What's there?",
          "ipa": "/wɒts ðeə?/",
          "ru": "Что там?"
        },
        {
          "en": "What's on this table?",
          "ipa": "/wɒts ɒn ðɪs ˈteɪbəl?/",
          "ru": "Что находится на этом столе?"
        },
        {
          "en": "What's on the table?",
          "ipa": "/wɒts ɒn ðə ˈteɪbəl?/",
          "ru": "Что находится на столе?"
