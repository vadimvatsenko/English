{
  "sections": [
    {
      "title": "Future Simple questions with will",
      "rule": "Will + subject + verb ...? Например: Will you buy it? / Will he come soon?",
      "examples": [
        {
          "en": "Will you buy it?",
          "ipa": "/wɪl juː baɪ ɪt?/",
          "ru": "Ты будешь покупать это?"
        },
        {
          "en": "Will you buy these tickets?",
          "ipa": "/wɪl juː baɪ ðiːz ˈtɪkɪts?/",
          "ru": "Ты купишь эти билеты?"
        },
        {
          "en": "Will you do it?",
          "ipa": "/wɪl juː duː ɪt?/",
          "ru": "Ты будешь делать это?"
        },
        {
          "en": "Will you call him?",
          "ipa": "/wɪl juː kɔːl hɪm?/",
          "ru": "Ты позвонишь ему?"
        },
        {
          "en": "Will you go there?",
          "ipa": "/wɪl juː ɡəʊ ðeə?/",
          "ru": "Ты пойдёшь туда?"
        },
        {
          "en": "Will you go to this place?",
          "ipa": "/wɪl juː ɡəʊ tuː ðɪs pleɪs?/",
          "ru": "Ты пойдёшь в это место?"
        },
        {
          "en": "Will you play?",
          "ipa": "/wɪl juː pleɪ?/",
          "ru": "Ты будешь играть?"
        },
        {
          "en": "Will you dance?",
          "ipa": "/wɪl juː dɑːns?/",
          "ru": "Ты будешь танцевать?"
        },
        {
          "en": "Will you help me?",
          "ipa": "/wɪl juː help miː?/",
          "ru": "Ты поможешь мне?"
        }
      ]
    },
    {
      "title": "Future Simple questions with places and movement",
      "rule": "Will + subject + go / come / be + place/time ...?",
      "examples": [
        {
          "en": "Will you go to the park?",
          "ipa": "/wɪl juː ɡəʊ tuː ðə pɑːk?/",
          "ru": "Ты пойдёшь в парк?"
        },
        {
          "en": "Will you go to the beach?",
          "ipa": "/wɪl juː ɡəʊ tuː ðə biːtʃ?/",
          "ru": "Ты пойдёшь на пляж?"
        },
        {
          "en": "Will you be there?",
          "ipa": "/wɪl juː biː ðeə?/",
          "ru": "Ты будешь там?"
        },
        {
          "en": "Will you be there tomorrow?",
          "ipa": "/wɪl juː biː ðeə təˈmɒrəʊ?/",
          "ru": "Ты будешь там завтра?"
        },
        {
          "en": "Will he be with you?",
          "ipa": "/wɪl hiː biː wɪð juː?/",
          "ru": "Он будет с тобой?"
        },
        {
          "en": "Will you be at work tomorrow?",
          "ipa": "/wɪl juː biː æt wɜːk təˈmɒrəʊ?/",
          "ru": "Ты будешь на работе завтра?"
        },
        {
          "en": "Will you be at home?",
          "ipa": "/wɪl juː biː æt həʊm?/",
          "ru": "Ты будешь дома?"
        },
        {
          "en": "Will you stay at home?",
          "ipa": "/wɪl juː steɪ æt həʊm?/",
          "ru": "Ты останешься дома?"
        },
        {
          "en": "Will they be there?",
          "ipa": "/wɪl ðeɪ biː ðeə?/",
          "ru": "Они будут там?"
        },
        {
          "en": "Will she come home soon?",
          "ipa": "/wɪl ʃiː kʌm həʊm suːn?/",
          "ru": "Она скоро придёт домой?"
        },
        {
          "en": "Will he come back soon?",
          "ipa": "/wɪl hiː kʌm bæk suːn?/",
          "ru": "Он скоро вернётся?"
        }
      ]
    },
    {
      "title": "Future Simple questions with decisions and evaluation",
      "rule": "Will it be ...? — вопросы о результате, качестве, цене или возможности.",
      "examples": [
        {
          "en": "Will it be right?",
          "ipa": "/wɪl ɪt biː raɪt?/",
          "ru": "Это будет правильно?"
        },
        {
          "en": "Will it be more expensive?",
          "ipa": "/wɪl ɪt biː mɔː ɪkˈspensɪv?/",
          "ru": "Это будет дороже?"
        },
        {
          "en": "Will it be cheaper?",
          "ipa": "/wɪl ɪt biː ˈtʃiːpə?/",
          "ru": "Это будет дешевле?"
        },
        {
          "en": "Will it be the best choice?",
          "ipa": "/wɪl ɪt biː ðə best tʃɔɪs?/",
          "ru": "Это будет лучший выбор?"
        },
        {
          "en": "Will it be the best decision?",
          "ipa": "/wɪl ɪt biː ðə best dɪˈsɪʒən?/",
          "ru": "Это будет лучшее решение?"
        },
        {
          "en": "Will it be the best choice in this situation?",
          "ipa": "/wɪl ɪt biː ðə best tʃɔɪs ɪn ðɪs ˌsɪtʃuˈeɪʃən?/",
          "ru": "Это будет лучший выбор в этой ситуации?"
        },
        {
          "en": "Will it be the best decision in this situation?",
          "ipa": "/wɪl ɪt biː ðə best dɪˈsɪʒən ɪn ðɪs ˌsɪtʃuˈeɪʃən?/",
          "ru": "Это будет лучшее решение в этой ситуации?"
        },
        {
          "en": "Will it be better?",
          "ipa": "/wɪl ɪt biː ˈbetə?/",
          "ru": "Это будет лучше?"
        },
        {
          "en": "Will it be possible?",
          "ipa": "/wɪl ɪt biː ˈpɒsəbl?/",
          "ru": "Это будет возможно?"
        },
        {
          "en": "Will it be possible soon?",
          "ipa": "/wɪl ɪt biː ˈpɒsəbl suːn?/",
          "ru": "Это будет скоро возможно?"
        },
        {
          "en": "Will it be free?",
          "ipa": "/wɪl ɪt biː friː?/",
          "ru": "Это будет бесплатно?"
        }
      ]
    },
    {
      "title": "Future Simple questions with travel and plans",
      "rule": "Will + subject + go + country/time ...?",
      "examples": [
        {
          "en": "Will you go to France this year?",
          "ipa": "/wɪl juː ɡəʊ tuː frɑːns ðɪs jɪə?/",
          "ru": "Ты поедешь во Францию в этом году?"
        },
        {
          "en": "Will you go to Germany next year?",
          "ipa": "/wɪl juː ɡəʊ tuː ˈdʒɜːməni nekst jɪə?/",
          "ru": "Вы поедете в Германию в следующем году?"
        },
        {
          "en": "Will you go to England next month?",
          "ipa": "/wɪl juː ɡəʊ tuː ˈɪŋɡlənd nekst mʌnθ?/",
          "ru": "Ты поедешь в Англию в следующем месяце?"
        }
      ]
    },
    {
      "title": "Future Simple questions with actions and checking",
      "rule": "Will + subject + know / check / understand / join ...?",
      "examples": [
        {
          "en": "Will we know it?",
          "ipa": "/wɪl wiː nəʊ ɪt?/",
          "ru": "Мы узнаем это?"
        },
        {
          "en": "Will you check this information?",
          "ipa": "/wɪl juː tʃek ðɪs ˌɪnfəˈmeɪʃən?/",
          "ru": "Ты проверишь эту информацию?"
        },
        {
          "en": "Will you check it again?",
          "ipa": "/wɪl juː tʃek ɪt əˈɡen?/",
          "ru": "Ты будешь проверять это снова?"
        },
        {
          "en": "Will they join us?",
          "ipa": "/wɪl ðeɪ dʒɔɪn ʌs?/",
          "ru": "Они присоединятся к нам?"
        },
        {
          "en": "Will they join our company?",
          "ipa": "/wɪl ðeɪ dʒɔɪn ˈaʊə ˈkʌmpəni?/",
          "ru": "Они присоединятся к нашей компании?"
        },
        {
          "en": "Will he understand it?",
          "ipa": "/wɪl hiː ˌʌndəˈstænd ɪt?/",
          "ru": "Он поймёт это?"
        }
      ]
    },
    {
      "title": "Future Simple questions with buying and renting",
      "rule": "Will + subject + buy / order / rent ...?",
      "examples": [
        {
          "en": "Will you order this new model online?",
          "ipa": "/wɪl juː ˈɔːdə ðɪs njuː ˈmɒdl ˈɒnlaɪn?/",
          "ru": "Ты будешь заказывать эту новую модель онлайн?"
        },
        {
          "en": "Will you buy a car?",
          "ipa": "/wɪl juː baɪ ə kɑː?/",
          "ru": "Ты будешь покупать машину?"
        },
        {
          "en": "Will he buy another car?",
          "ipa": "/wɪl hiː baɪ əˈnʌðə kɑː?/",
          "ru": "Он купит другую машину?"
        },
        {
          "en": "Will you buy a house?",
          "ipa": "/wɪl juː baɪ ə haʊs?/",
          "ru": "Ты будешь покупать дом?"
        },
        {
          "en": "Will she buy an apartment?",
          "ipa": "/wɪl ʃiː baɪ ən əˈpɑːtmənt?/",
          "ru": "Она будет покупать квартиру?"
        },
        {
          "en": "Will you rent a house?",
          "ipa": "/wɪl juː rent ə haʊs?/",
          "ru": "Вы будете снимать дом?"
        },
        {
          "en": "Will they rent an apartment?",
          "ipa": "/wɪl ðeɪ rent ən əˈpɑːtmənt?/",
          "ru": "Они будут снимать квартиру?"
        }
      ]
    },
    {
      "title": "Future Simple questions with sending and telling",
      "rule": "Will + subject + send / tell + object ...?",
      "examples": [
        {
          "en": "Will you send him a message?",
          "ipa": "/wɪl juː send hɪm ə ˈmesɪdʒ?/",
          "ru": "Ты отправишь ему сообщение?"
        },
        {
          "en": "Will you send her a letter?",
          "ipa": "/wɪl juː send hɜː ə ˈletə?/",
          "ru": "Ты отправишь ей письмо?"
        },
        {
          "en": "Will you tell her this thing?",
          "ipa": "/wɪl juː tel hɜː ðɪs θɪŋ?/",
          "ru": "Ты скажешь ей эту вещь?"
        }
      ]
    }
  ]
}
