        },
        {
          "en": "We don't see any changes",
          "ipa": "/wiː dəʊnt siː ˈeni ˈtʃeɪndʒɪz/",
          "ru": "Мы не видим каких-либо изменений"
        },
        {
          "en": "They don't want to say it",
