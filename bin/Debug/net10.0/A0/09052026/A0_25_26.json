  "sections": [
    {
      "title": "Future Simple questions with will",
      "rule": "Will + subject + verb ...? Например: Will you buy it? / Will he come soon?",
      "examples": [
        { "en": "Will you buy it?", "ipa": "/wɪl juː baɪ ɪt?/", "ru": "Ты будешь покупать это?" },
        { "en": "Will you buy these tickets?", "ipa": "/wɪl juː baɪ ðiːz ˈtɪkɪts?/", "ru": "Ты купишь эти билеты?" },
